# LLM provider (Azure-style proxy or vanilla OpenAI)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://ai-proxy.lab.epam.com

# Aliases recognised by the vendored RAG modules (same value as above)
API_KEY=${OPENAI_API_KEY}
ENDPOINT_URL=${OPENAI_BASE_URL}

# Runtime directories
VECTOR_DB_DIR=./vector-db
RESULTS_DIR=./results
DATA_DIR=./dataset

# Optional: integrity key for the BM25 index file
BM25_HMAC_KEY=change-me-in-production
